@model UserIndexViewModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

@section TopbarAction {
    @if (Model.CanCreate)
    {
        <a class="btn btn-primary" asp-action="Create">Tạo người dùng</a>
    }
}

@if (TempData["Success"] is string ok)
{
    <div class="flash flash-success">@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="flash flash-error">@err</div>
}

@if (Model.TotalAdmins is int adminCount)
{
    <div class="flash flash-info">Toàn hệ thống hiện có <strong>@adminCount</strong> tài khoản Admin.</div>
}

<h3 class="section-heading">Nhân viên công ty (@Model.CompanyUsers.Count)</h3>
@if (Model.CompanyUsers.Any())
{
    <partial name="_UserTable" model="Model.CompanyUsers" />
}
else
{
    <div class="card"><div class="empty"><p class="muted">Chưa có nhân viên công ty nào trong phạm vi của bạn.</p></div></div>
}

@if (Model.PersonalUsers.Any())
{
    <h3 class="section-heading mt-2">Tài khoản cá nhân (@Model.PersonalUsers.Count)</h3>
    <p class="muted text-sm mb-1">Người tự đăng ký hoặc đăng nhập bằng Google — tự quản lý công việc cá nhân, không thuộc cơ cấu công ty.</p>
    <partial name="_UserTable" model="Model.PersonalUsers" />
}
