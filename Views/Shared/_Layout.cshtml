@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var fullName = User.FindFirstValue(ClaimTypes.Name) ?? "";
    var role = User.FindFirstValue(ClaimTypes.Role);

    // Đánh dấu menu đang active theo controller (và action với Tasks/Lịch ngày).
    string? controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string? action = ViewContext.RouteData.Values["action"]?.ToString();
    bool isTasks = string.Equals(controller, "Tasks", StringComparison.OrdinalIgnoreCase);
    var calendarActions = new[] { "Timeline", "Week", "Month" };
    bool isCalendar = isTasks && calendarActions.Contains(action, StringComparer.OrdinalIgnoreCase);
    string Active(string name) => string.Equals(controller, name, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    // Nhãn ngữ cảnh hiển thị phía trên tiêu đề trang (giúp điều hướng rõ ràng).
    string sectionLabel = isCalendar ? "Lịch" : controller switch
    {
        "Dashboard" => "Tổng quan",
        "Workspaces" => "Không gian làm việc",
        "Projects" => "Dự án",
        "Tasks" => "Công việc",
        "Notifications" => "Thông báo",
        "Users" => "Quản trị người dùng",
        "Pages" => "Tài liệu",
        _ => "Cetee"
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cetee</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (isAuthenticated)
{
    <div class="app-shell">
        <aside class="sidebar">
            <a asp-controller="Home" asp-action="Index" class="sidebar-brand" style="text-decoration:none;color:inherit;">
                <span class="brand-logo">C</span>
                <span>Cetee</span>
            </a>

            <div class="sidebar-section">Tổng quan</div>
            <nav class="sidebar-nav">
                @if (Roles.CanAccessDashboard(role))
                {
                    <a class="nav-item @Active("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                        <svg class="icon" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                        <span class="nav-label">Dashboard</span>
                    </a>
                }
                <a class="nav-item @Active("Workspaces")" asp-controller="Workspaces" asp-action="Index">
                    <svg class="icon" viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                    <span class="nav-label">Workspaces</span>
                </a>
                <a class="nav-item @Active("Projects")" asp-controller="Projects" asp-action="Index">
                    <svg class="icon" viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                    <span class="nav-label">Projects</span>
                </a>
                <a class="nav-item @(isTasks && !isCalendar ? "active" : "")" asp-controller="Tasks" asp-action="Index">
                    <svg class="icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 11l2.5 2.5L16 8"/></svg>
                    <span class="nav-label">Tasks</span>
                </a>
                <a class="nav-item @(isCalendar ? "active" : "")" asp-controller="Tasks" asp-action="Timeline">
                    <svg class="icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span class="nav-label">Lịch</span>
                </a>
                <a class="nav-item @Active("Notifications")" asp-controller="Notifications" asp-action="Index">
                    <svg class="icon" viewBox="0 0 24 24"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
                    <span class="nav-label">Notifications</span>
                    @await Component.InvokeAsync("NotificationBadge")
                </a>
                @if (role == Roles.SuperAdmin || role == Roles.Admin || role == Roles.Manager)
                {
                    <a class="nav-item @Active("Users")" asp-controller="Users" asp-action="Index">
                        <svg class="icon" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        <span class="nav-label">Người dùng</span>
                    </a>
                }
            </nav>

            <div class="sidebar-user">
                <partial name="_Avatar" model="@fullName" />
                <div class="user-meta">
                    <div class="user-name">@fullName</div>
                    <div class="user-role">@Roles.Label(role)</div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn" title="Đăng xuất">
                        <svg class="icon" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </button>
                </form>
            </div>
        </aside>
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <div class="main">
            <header class="topbar">
                <button type="button" class="nav-toggle" id="navToggle" aria-label="Mở menu">
                    <svg class="icon" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                </button>
                <div class="topbar-heading">
                    <span class="topbar-eyebrow">@sectionLabel</span>
                    <h1 class="topbar-title">@ViewData["Title"]</h1>
                </div>
                <form class="topbar-search" method="get" asp-controller="Tasks" asp-action="Index">
                    <svg class="icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" name="q" placeholder="Tìm công việc theo tên..." />
                </form>
                <div class="topbar-actions">
                    @RenderSection("TopbarAction", required: false)
                    <a class="icon-btn" asp-controller="Notifications" asp-action="Index" title="Thông báo">
                        <svg class="icon" viewBox="0 0 24 24"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
                        @await Component.InvokeAsync("NotificationBadge")
                    </a>
                    <div class="topbar-user">
                        <div class="user-meta">
                            <div class="user-name">@fullName</div>
                            <div class="user-role">@Roles.Label(role)</div>
                        </div>
                        <partial name="_Avatar" model="@fullName" />
                    </div>
                </div>
            </header>

            <div class="toast-stack" id="toastStack">
                @if (TempData["Success"] is string fs) { <div class="toast toast-success"><span>@fs</span><button type="button" class="toast-x" aria-label="Đóng">&times;</button></div> }
                @if (TempData["Info"] is string fi) { <div class="toast toast-info"><span>@fi</span><button type="button" class="toast-x" aria-label="Đóng">&times;</button></div> }
                @if (TempData["Error"] is string fe) { <div class="toast toast-error"><span>@fe</span><button type="button" class="toast-x" aria-label="Đóng">&times;</button></div> }
            </div>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>
    <script>
    (function () {
        var shell = document.querySelector('.app-shell');
        var toggle = document.getElementById('navToggle');
        var overlay = document.getElementById('sidebarOverlay');
        if (!shell || !toggle) return;
        var close = function () { shell.classList.remove('nav-open'); };
        toggle.addEventListener('click', function () { shell.classList.toggle('nav-open'); });
        if (overlay) overlay.addEventListener('click', close);
        shell.querySelectorAll('.sidebar .nav-item, .sidebar-brand').forEach(function (a) {
            a.addEventListener('click', function () { if (window.innerWidth <= 760) close(); });
        });
        window.addEventListener('resize', function () { if (window.innerWidth > 760) close(); });

        // Toast: nút đóng + tự ẩn sau 4.5s
        document.querySelectorAll('#toastStack .toast').forEach(function (t) {
            var hide = function () { t.classList.add('toast-hide'); setTimeout(function () { t.remove(); }, 300); };
            var x = t.querySelector('.toast-x');
            if (x) x.addEventListener('click', hide);
            setTimeout(hide, 4500);
        });

        // Xác nhận trước thao tác xóa/gỡ (toàn cục) — dựa trên chữ nút submit
        document.addEventListener('submit', function (e) {
            var f = e.target;
            if (!f || f.dataset.noConfirm) return;
            var btn = f.querySelector('[type=submit]');
            var txt = ((btn && btn.textContent) || '').trim().toLowerCase();
            if (f.classList.contains('js-confirm') || /xóa|xoá|gỡ|delete|remove/.test(txt)) {
                if (!window.confirm('Bạn có chắc muốn thực hiện thao tác này?')) e.preventDefault();
            }
        });
    })();
    </script>
}
else
{
    @RenderBody()
}

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
