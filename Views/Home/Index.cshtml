@{
    ViewData["Title"] = "Cetee — Quản lý công việc nhóm";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cetee — Quản lý công việc nhóm, gọn gàng và rõ ràng</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="lp">
    <!-- Thanh điều hướng -->
    <header class="lp-nav">
        <div class="lp-container lp-nav-inner">
            <a class="lp-brand" href="/">
                <span class="brand-logo">C</span> Cetee
            </a>
            <nav class="lp-nav-links">
                <a href="#features">Tính năng</a>
                <a href="#how">Cách hoạt động</a>
                <a href="#why">Vì sao Cetee</a>
            </nav>
            <div class="lp-nav-actions">
                <a class="btn btn-ghost" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                <a class="btn btn-primary" href="#" data-trial>Dùng thử miễn phí</a>
            </div>
        </div>
    </header>

    <!-- Hero -->
    <section class="lp-hero">
        <div class="lp-hero-bg" aria-hidden="true"></div>
        <div class="lp-container lp-hero-grid">
            <div class="lp-hero-copy">
                <span class="lp-eyebrow"><span class="lp-eyebrow-dot"></span> Nền tảng quản lý công việc cho đội ngũ hiện đại</span>
                <h1>Quản lý công việc nhóm <span class="lp-grad">rõ ràng, hoàn thành nhanh hơn</span>.</h1>
                <p>Cetee hợp nhất workspace, dự án, bảng Kanban và lịch tiến độ vào một nền tảng duy nhất —
                    để cả đội luôn biết việc gì cần làm, ai phụ trách và khi nào hoàn thành.</p>
                <div class="lp-hero-cta">
                    <a class="btn btn-primary btn-lg" href="#" data-trial>Dùng thử miễn phí</a>
                    <a class="btn btn-secondary btn-lg" href="#features">Khám phá tính năng</a>
                </div>
                <div class="lp-trust">
                    <span><svg class="lp-check" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Miễn phí để bắt đầu</span>
                    <span><svg class="lp-check" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Không cần thẻ tín dụng</span>
                    <span><svg class="lp-check" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Thiết lập trong 1 phút</span>
                </div>
            </div>

            <!-- Mockup sản phẩm (vẽ bằng CSS, mô phỏng bảng Kanban) -->
            <div class="lp-hero-art" aria-hidden="true">
                <div class="lp-hero-glow"></div>
                <div class="lp-float lp-float-1">
                    <span class="lp-float-ic ok"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>
                    <div><b>Tiến độ dự án</b><small>Hoàn thành 78%</small></div>
                </div>
                <div class="lp-float lp-float-2">
                    <span class="lp-float-ic bell"><svg viewBox="0 0 24 24"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg></span>
                    <div><b>Bạn được giao việc</b><small>Tích hợp VNPay</small></div>
                </div>
                <div class="lp-mock">
                    <div class="lp-mock-bar">
                        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
                        <span class="lp-mock-title">Website Thương mại điện tử · Kanban</span>
                    </div>
                    <div class="lp-mock-body">
                        <div class="lp-col">
                            <div class="lp-col-h">Cần làm <b>3</b></div>
                            <div class="lp-mc"><span class="t high">Cao</span>Kiểm thử luồng đặt hàng</div>
                            <div class="lp-mc"><span class="t low">Thấp</span>Cảnh báo hàng sắp hết</div>
                            <div class="lp-mc"><span class="t med">TB</span>Màn hình chi tiết SP</div>
                        </div>
                        <div class="lp-col">
                            <div class="lp-col-h">Đang làm <b>2</b></div>
                            <div class="lp-mc"><span class="t high">Cao</span>Tích hợp VNPay
                                <span class="lp-ppl"><i class="a c0"></i><i class="a c1"></i><i class="a c3"></i></span></div>
                            <div class="lp-mc"><span class="t med">TB</span>API giỏ hàng</div>
                        </div>
                        <div class="lp-col">
                            <div class="lp-col-h">Hoàn thành <b>2</b></div>
                            <div class="lp-mc done"><span class="t done">Xong</span>Thiết kế trang chủ</div>
                            <div class="lp-mc done"><span class="t done">Xong</span>Đăng nhập app</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Dải số liệu / định vị -->
    <section class="lp-metrics-wrap">
        <div class="lp-container">
            <p class="lp-metrics-label">Được thiết kế cho cách vận hành của đội ngũ hiện đại</p>
            <div class="lp-metrics">
                <div class="lp-metric"><span class="n">4</span><span class="l">cấp phân quyền công ty</span></div>
                <div class="lp-metric"><span class="n">3</span><span class="l">chế độ lịch tiến độ</span></div>
                <div class="lp-metric"><span class="n">100%</span><span class="l">chạy trên trình duyệt</span></div>
                <div class="lp-metric"><span class="n">0đ</span><span class="l">chi phí để bắt đầu</span></div>
            </div>
        </div>
    </section>

    <!-- Tính năng -->
    <section id="features" class="lp-section">
        <div class="lp-container">
            <div class="lp-section-head">
                <span class="lp-tag">TÍNH NĂNG</span>
                <h2>Tất cả công cụ vận hành dự án — trong một nơi</h2>
                <p>Từ giao việc đến theo dõi tiến độ, mọi thứ được hợp nhất để đội ngũ tập trung vào điều quan trọng nhất.</p>
            </div>
            <div class="lp-features">
                <div class="lp-feature">
                    <div class="lp-fic fic-1"><svg class="icon" viewBox="0 0 24 24"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></div>
                    <h3>Workspace &amp; dự án</h3>
                    <p>Cấu trúc công việc theo không gian nhóm và dự án, phân định rõ chủ sở hữu và thành viên.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-fic fic-2"><svg class="icon" viewBox="0 0 24 24"><rect x="3" y="4" width="5" height="16" rx="1"/><rect x="10" y="4" width="5" height="11" rx="1"/><rect x="17" y="4" width="4" height="7" rx="1"/></svg></div>
                    <h3>Bảng Kanban trực quan</h3>
                    <p>Kéo–thả công việc qua các cột Cần làm · Đang làm · Hoàn thành, cập nhật trạng thái tức thì.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-fic fic-3"><svg class="icon" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
                    <h3>Lịch &amp; tiến độ dự án</h3>
                    <p>Lên lịch theo Ngày / Tuần / Tháng và đo lường mức độ hoàn thành của cả dự án theo từng kỳ.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-fic fic-4"><svg class="icon" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
                    <h3>Phân quyền theo cấp bậc</h3>
                    <p>Mô hình Super Admin → Admin → Manager → User; mỗi cấp chỉ quản lý đúng phạm vi đội của mình.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-fic fic-5"><svg class="icon" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div>
                    <h3>Cộng tác đa phụ trách</h3>
                    <p>Giao một công việc cho nhiều thành viên cùng thực hiện; mỗi người đều nhận được thông báo.</p>
                </div>
                <div class="lp-feature">
                    <div class="lp-fic fic-6"><svg class="icon" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
                    <h3>Bảo mật &amp; đăng nhập</h3>
                    <p>Đăng nhập Google chỉ một chạm và khôi phục mật khẩu an toàn bằng mã OTP gửi qua email.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Khám phá sâu: các khối tính năng xen kẽ (kiểu Notion) -->
    <section class="lp-section">
        <div class="lp-container lp-shows">
            <!-- Row 1: Workspace & tiến độ -->
            <div class="lp-show">
                <div class="lp-show-copy">
                    <span class="lp-tag">KHÔNG GIAN LÀM VIỆC</span>
                    <h2>Mọi dự án, gọn trong một không gian</h2>
                    <p>Nhóm công việc theo workspace của từng đội, mở dự án bên trong và nắm tiến độ tổng quan chỉ trong một cái nhìn.</p>
                    <ul class="lp-show-feat">
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Workspace cho từng đội, dự án không giới hạn</li>
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Thanh tiến độ theo % công việc hoàn thành</li>
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Phân định chủ sở hữu &amp; thành viên</li>
                    </ul>
                </div>
                <div class="lp-show-art">
                    <div class="lp-panel">
                        <div class="lp-panel-title">Tiến độ dự án</div>
                        <div class="lp-pr"><div class="lp-pr-top"><span>Website Thương mại điện tử</span><span class="lp-pr-pct">72%</span></div><div class="progress"><div class="progress-bar" style="width:72%"></div></div></div>
                        <div class="lp-pr"><div class="lp-pr-top"><span>Ứng dụng Mobile Bán hàng</span><span class="lp-pr-pct">45%</span></div><div class="progress"><div class="progress-bar" style="width:45%"></div></div></div>
                        <div class="lp-pr"><div class="lp-pr-top"><span>Hệ thống Quản trị Nội bộ</span><span class="lp-pr-pct">90%</span></div><div class="progress"><div class="progress-bar green" style="width:90%"></div></div></div>
                    </div>
                </div>
            </div>

            <!-- Row 2: Lịch & tiến độ (đảo chiều) -->
            <div class="lp-show rev">
                <div class="lp-show-copy">
                    <span class="lp-tag">LỊCH &amp; TIẾN ĐỘ</span>
                    <h2>Nắm tiến độ cả tháng trong một màn hình</h2>
                    <p>Xếp lịch công việc theo Ngày / Tuần / Tháng và đo lường mức độ hoàn thành của cả dự án theo từng kỳ — biết ngay đang chậm ở đâu.</p>
                    <ul class="lp-show-feat">
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Ba chế độ lịch: Ngày, Tuần, Tháng</li>
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Tỷ lệ hoàn thành theo từng kỳ</li>
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Kéo–thả công việc để xếp lịch</li>
                    </ul>
                </div>
                <div class="lp-show-art">
                    <div class="lp-panel">
                        <div class="lp-panel-head">Tháng 6 · <b>78% hoàn thành</b></div>
                        @{
                            var dots = new Dictionary<int, string> {
                                {2,"ok"},{4,"hi"},{6,"ok"},{9,"md"},{11,"ok"},{12,"hi"},{15,"ok"},
                                {16,"md"},{18,"ok"},{19,"hi"},{20,"ok"},{23,"md"},{25,"ok"},{26,"hi"}
                            };
                        }
                        <div class="lp-cal-mini">
                            @for (int d = 1; d <= 28; d++)
                            {
                                var cls = d == 21 ? "today" : (dots.ContainsKey(d) ? "has " + dots[d] : "");
                                <span class="lp-cd @cls">@d</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Row 3: Phân quyền & cộng tác -->
            <div class="lp-show">
                <div class="lp-show-copy">
                    <span class="lp-tag">CỘNG TÁC</span>
                    <h2>Phân quyền &amp; giao việc rõ ràng</h2>
                    <p>Mô hình phân cấp công ty giúp mỗi người thấy đúng phạm vi của mình; giao một việc cho nhiều người cùng làm và ai cũng được thông báo.</p>
                    <ul class="lp-show-feat">
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Phân cấp Super Admin → Admin → Manager → User</li>
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Giao việc đa phụ trách</li>
                        <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Thông báo khi được giao việc</li>
                    </ul>
                </div>
                <div class="lp-show-art">
                    <div class="lp-panel">
                        <div class="lp-panel-title">Thành viên dự án</div>
                        <div class="lp-mem"><span class="avatar avatar-c0">PK</span><span class="lp-mem-name">Phan Anh Khoa</span><span class="tag tag-doing plain">Admin</span></div>
                        <div class="lp-mem"><span class="avatar avatar-c1">LQ</span><span class="lp-mem-name">Lê Minh Quân</span><span class="tag tag-medium plain">Manager</span></div>
                        <div class="lp-mem"><span class="avatar avatar-c3">VM</span><span class="lp-mem-name">Võ Thị Mai</span><span class="tag tag-todo plain">User</span></div>
                        <div class="lp-panel-foot">
                            <span>Đa phụ trách</span>
                            <span class="avatar-stack">
                                <span class="avatar avatar-c2">TĐ</span>
                                <span class="avatar avatar-c4">BH</span>
                                <span class="avatar avatar-c5">HN</span>
                                <span class="avatar avatar-more">+2</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Cách hoạt động -->
    <section id="how" class="lp-section lp-section-alt">
        <div class="lp-container">
            <div class="lp-section-head">
                <span class="lp-tag">BẮT ĐẦU NHANH</span>
                <h2>Vận hành chỉ trong 3 bước</h2>
                <p>Không cần cài đặt, không cấu hình phức tạp — đăng ký và bắt đầu ngay trên trình duyệt.</p>
            </div>
            <div class="lp-steps">
                <div class="lp-step">
                    <div class="lp-step-no">1</div>
                    <h3>Tạo tài khoản</h3>
                    <p>Đăng ký bằng email hoặc Google chỉ trong vài giây.</p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-no">2</div>
                    <h3>Lập workspace &amp; dự án</h3>
                    <p>Tạo không gian làm việc, mời thành viên và mở các dự án.</p>
                </div>
                <div class="lp-step">
                    <div class="lp-step-no">3</div>
                    <h3>Giao việc &amp; theo dõi</h3>
                    <p>Thêm công việc, kéo–thả trên Kanban và nắm tiến độ trên lịch.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Lời chứng thực -->
    <section class="lp-section">
        <div class="lp-container">
            <div class="lp-section-head">
                <span class="lp-tag">KHÁCH HÀNG</span>
                <h2>Đội ngũ làm việc hiệu quả hơn với Cetee</h2>
                <p>Những chia sẻ từ người dùng đã đưa cả nhóm về cùng một nhịp.</p>
            </div>
            <div class="lp-quotes">
                <figure class="lp-quote">
                    <blockquote>“Cả nhóm cuối cùng đã nhìn chung một bức tranh — việc gì đang làm, ai phụ trách và bao giờ xong đều rõ ràng.”</blockquote>
                    <figcaption><span class="avatar avatar-c0">TT</span><div><b>Thu Trang</b><small>Trưởng nhóm Sản phẩm</small></div></figcaption>
                </figure>
                <figure class="lp-quote">
                    <blockquote>“Lịch Tuần và Tháng giúp tôi biết chính xác dự án còn bao nhiêu việc và đang chậm ở khâu nào.”</blockquote>
                    <figcaption><span class="avatar avatar-c3">MQ</span><div><b>Minh Quân</b><small>Quản lý Dự án</small></div></figcaption>
                </figure>
                <figure class="lp-quote">
                    <blockquote>“Thiết lập trong vài phút, không cần đào tạo. Nhân viên mới bắt nhịp công việc gần như ngay lập tức.”</blockquote>
                    <figcaption><span class="avatar avatar-c1">BC</span><div><b>Bảo Châu</b><small>Chủ doanh nghiệp</small></div></figcaption>
                </figure>
            </div>
        </div>
    </section>

    <!-- Vì sao -->
    <section id="why" class="lp-section">
        <div class="lp-container">
            <div class="lp-why-panel">
                <div class="lp-why-glow" aria-hidden="true"></div>
                <div class="lp-why-copy">
                    <span class="lp-tag light">VÌ SAO CETEE</span>
                    <h2>Gọn cho cá nhân. Đủ mạnh cho doanh nghiệp.</h2>
                    <p>Cá nhân có không gian riêng tối giản để tập trung; doanh nghiệp có phân cấp,
                        quản lý thành viên và báo cáo tiến độ — tất cả trên cùng một nền tảng.</p>
                    <a class="btn btn-lg lp-btn-light" href="#" data-trial>Dùng thử miễn phí</a>
                </div>
                <ul class="lp-checklist">
                    <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Phân cấp 4 tầng, mỗi cấp quản lý đúng phạm vi</li>
                    <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Kanban kéo–thả &amp; lịch Ngày / Tuần / Tháng</li>
                    <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Giao việc đa phụ trách &amp; thông báo tức thì</li>
                    <li><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg> Đăng nhập Google &amp; khôi phục mật khẩu bằng OTP</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="lp-section lp-section-alt">
        <div class="lp-container lp-faq-wrap">
            <div class="lp-section-head">
                <span class="lp-tag">GIẢI ĐÁP</span>
                <h2>Câu hỏi thường gặp</h2>
            </div>
            <div class="lp-faq">
                <details class="lp-faq-item">
                    <summary>Cetee có miễn phí không?<span class="lp-faq-ic"></span></summary>
                    <p>Có. Bạn có thể đăng ký và sử dụng miễn phí ngay trên trình duyệt, không cần thẻ tín dụng.</p>
                </details>
                <details class="lp-faq-item">
                    <summary>Tôi dùng cho mục đích cá nhân được không?<span class="lp-faq-ic"></span></summary>
                    <p>Được. Tài khoản cá nhân có một không gian riêng tối giản để tự quản lý công việc, tách biệt với cơ cấu công ty.</p>
                </details>
                <details class="lp-faq-item">
                    <summary>Cetee phù hợp với công ty quy mô nào?<span class="lp-faq-ic"></span></summary>
                    <p>Mọi quy mô. Mô hình phân cấp 4 tầng (Super Admin → Admin → Manager → User) giúp mỗi cấp chỉ quản lý đúng phạm vi đội của mình.</p>
                </details>
                <details class="lp-faq-item">
                    <summary>Dữ liệu và tài khoản có an toàn không?<span class="lp-faq-ic"></span></summary>
                    <p>Có. Cetee hỗ trợ đăng nhập Google và khôi phục mật khẩu an toàn bằng mã OTP gửi qua email.</p>
                </details>
                <details class="lp-faq-item">
                    <summary>Có cần cài đặt phần mềm không?<span class="lp-faq-ic"></span></summary>
                    <p>Không. Cetee chạy 100% trên trình duyệt — chỉ cần đăng ký và bắt đầu.</p>
                </details>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="lp-cta">
        <div class="lp-cta-glow" aria-hidden="true"></div>
        <div class="lp-container lp-cta-inner">
            <h2>Sẵn sàng nâng tầm cách đội ngũ làm việc?</h2>
            <p>Tạo tài khoản miễn phí và mời cả nhóm cùng tham gia ngay hôm nay.</p>
            <div class="lp-hero-cta">
                <a class="btn btn-lg lp-btn-light" href="#" data-trial>Dùng thử miễn phí</a>
                <a class="btn btn-lg lp-btn-ghost" asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </div>
        </div>
    </section>

    <footer class="lp-footer">
        <div class="lp-container lp-footer-grid">
            <div class="lp-footer-brand">
                <a href="/" class="lp-brand" style="text-decoration:none;color:inherit;"><span class="brand-logo">C</span> Cetee</a>
                <p>Nền tảng quản lý công việc nhóm — gọn gàng, rõ ràng và hiệu quả.</p>
            </div>
            <div class="lp-footer-col">
                <h4>Sản phẩm</h4>
                <a href="#features">Tính năng</a>
                <a href="#how">Cách hoạt động</a>
                <a href="#why">Vì sao Cetee</a>
            </div>
            <div class="lp-footer-col">
                <h4>Tài khoản</h4>
                <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
                <a asp-controller="Account" asp-action="Register">Đăng ký</a>
            </div>
        </div>
    </footer>

    @{
        // SVG con mắt (hiện/ẩn mật khẩu)
        var eyeSvg = "<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>";
    }

    <!-- Modal ĐĂNG NHẬP -->
    <div class="lp-modal" id="loginModal" hidden>
        <div class="lp-modal-backdrop" data-close></div>
        <div class="lp-modal-card" role="dialog" aria-modal="true" aria-label="Đăng nhập">
            <button type="button" class="lp-modal-x" data-close aria-label="Đóng">&times;</button>
            <h2 class="lp-modal-title">Đăng nhập</h2>
            <p class="lp-modal-sub">Đăng nhập để quản lý công việc của bạn</p>
            <div class="lp-modal-err" id="loginErr" hidden></div>
            <form id="loginForm" method="post" asp-controller="Account" asp-action="Login">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-control" name="Email" type="email" required placeholder="Nhập email của bạn" />
                </div>
                <div class="form-group">
                    <div class="lp-label-row">
                        <label class="form-label">Mật khẩu</label>
                        <a class="lp-link" asp-controller="Account" asp-action="ForgotPassword">Quên mật khẩu?</a>
                    </div>
                    <div class="lp-pass">
                        <input class="form-control" name="Password" type="password" required placeholder="Nhập mật khẩu" />
                        <button type="button" class="lp-eye" data-eye>@Html.Raw(eyeSvg)</button>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block btn-lg">Đăng nhập</button>
            </form>
            <div class="auth-divider"><span>Hoặc đăng nhập bằng</span></div>
            <a class="btn btn-google btn-block" asp-controller="Account" asp-action="ExternalLogin">
                <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9 3.6l6.7-6.7C35.6 2.6 30.2 0 24 0 14.6 0 6.5 5.4 2.6 13.2l7.8 6.1C12.3 13.3 17.7 9.5 24 9.5z"/><path fill="#4285F4" d="M46.1 24.5c0-1.6-.1-2.7-.4-3.9H24v7.4h12.7c-.3 2.1-1.6 5.2-4.6 7.3l7.1 5.5c4.3-3.9 6.9-9.7 6.9-16.3z"/><path fill="#FBBC05" d="M10.4 28.7c-.5-1.4-.8-2.9-.8-4.7s.3-3.3.8-4.7l-7.8-6.1C1 16.5 0 20.1 0 24s1 7.5 2.6 10.8l7.8-6.1z"/><path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.6l-7.1-5.5c-2 1.4-4.6 2.3-8.1 2.3-6.3 0-11.7-3.8-13.6-9.3l-7.8 6.1C6.5 42.6 14.6 48 24 48z"/></svg>
                Tiếp tục với Google
            </a>
            <p class="lp-modal-switch">Chưa có tài khoản? <a href="#" data-modal="register">Đăng ký ngay</a></p>
        </div>
    </div>

    <!-- Modal ĐĂNG KÝ -->
    <div class="lp-modal" id="registerModal" hidden>
        <div class="lp-modal-backdrop" data-close></div>
        <div class="lp-modal-card" role="dialog" aria-modal="true" aria-label="Đăng ký">
            <button type="button" class="lp-modal-x" data-close aria-label="Đóng">&times;</button>
            <h2 class="lp-modal-title">Đăng ký</h2>
            <p class="lp-modal-sub">Tạo tài khoản miễn phí để bắt đầu</p>
            <div class="lp-modal-err" id="registerErr" hidden></div>
            <form id="registerForm" method="post" asp-controller="Account" asp-action="Register">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Họ và tên</label>
                    <input class="form-control" name="FullName" required placeholder="Nhập họ tên hiển thị" />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-control" name="Email" type="email" required placeholder="Nhập email của bạn" />
                </div>
                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <div class="lp-pass">
                        <input class="form-control" name="Password" type="password" required placeholder="Tối thiểu 6 ký tự" />
                        <button type="button" class="lp-eye" data-eye>@Html.Raw(eyeSvg)</button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Xác nhận mật khẩu</label>
                    <div class="lp-pass">
                        <input class="form-control" name="ConfirmPassword" type="password" required placeholder="Nhập lại mật khẩu" />
                        <button type="button" class="lp-eye" data-eye>@Html.Raw(eyeSvg)</button>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block btn-lg">Đăng ký ngay</button>
            </form>
            <div class="auth-divider"><span>Hoặc đăng ký bằng</span></div>
            <a class="btn btn-google btn-block" asp-controller="Account" asp-action="ExternalLogin">
                <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9 3.6l6.7-6.7C35.6 2.6 30.2 0 24 0 14.6 0 6.5 5.4 2.6 13.2l7.8 6.1C12.3 13.3 17.7 9.5 24 9.5z"/><path fill="#4285F4" d="M46.1 24.5c0-1.6-.1-2.7-.4-3.9H24v7.4h12.7c-.3 2.1-1.6 5.2-4.6 7.3l7.1 5.5c4.3-3.9 6.9-9.7 6.9-16.3z"/><path fill="#FBBC05" d="M10.4 28.7c-.5-1.4-.8-2.9-.8-4.7s.3-3.3.8-4.7l-7.8-6.1C1 16.5 0 20.1 0 24s1 7.5 2.6 10.8l7.8-6.1z"/><path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.6l-7.1-5.5c-2 1.4-4.6 2.3-8.1 2.3-6.3 0-11.7-3.8-13.6-9.3l-7.8 6.1C6.5 42.6 14.6 48 24 48z"/></svg>
                Tiếp tục với Google
            </a>
            <p class="lp-modal-switch">Đã có tài khoản? <a href="#" data-modal="login">Đăng nhập</a></p>
        </div>
    </div>

    <!-- Form ẩn cho "Dùng thử miễn phí" (1 chạm: tạo tài khoản dùng thử + đăng nhập) -->
    <form id="trialForm" method="post" asp-controller="Account" asp-action="Trial" hidden>
        @Html.AntiForgeryToken()
    </form>

    <script>
        (function () {
            const body = document.body;
            function closeAll() {
                document.querySelectorAll('.lp-modal').forEach(m => m.hidden = true);
                body.style.overflow = '';
            }
            function open(name) {
                closeAll();
                const m = document.getElementById(name + 'Modal');
                if (!m) return;
                m.hidden = false;
                body.style.overflow = 'hidden';
                const f = m.querySelector('input'); if (f) setTimeout(() => f.focus(), 30);
            }

            // Biến các liên kết Đăng nhập / Đăng ký trên trang thành nút mở modal (vẫn còn trang riêng nếu tắt JS).
            document.querySelectorAll('a[href="/Account/Login"]').forEach(a =>
                a.addEventListener('click', e => { e.preventDefault(); open('login'); }));
            document.querySelectorAll('a[href="/Account/Register"]').forEach(a =>
                a.addEventListener('click', e => { e.preventDefault(); open('register'); }));
            document.querySelectorAll('[data-modal]').forEach(el =>
                el.addEventListener('click', e => { e.preventDefault(); open(el.dataset.modal); }));
            document.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', closeAll));
            document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAll(); });

            // Hiện/ẩn mật khẩu
            document.querySelectorAll('[data-eye]').forEach(btn => btn.addEventListener('click', () => {
                const i = btn.parentElement.querySelector('input');
                i.type = i.type === 'password' ? 'text' : 'password';
                btn.classList.toggle('on');
            }));

            // Gửi form bằng AJAX để báo lỗi ngay trong modal (không rời trang)
            function wire(formId, errId) {
                const form = document.getElementById(formId);
                const err = document.getElementById(errId);
                if (!form) return;
                form.addEventListener('submit', async e => {
                    e.preventDefault();
                    err.hidden = true;
                    const btn = form.querySelector('button[type=submit]');
                    const label = btn.textContent; btn.disabled = true; btn.textContent = 'Đang xử lý…';
                    try {
                        const res = await fetch(form.action, {
                            method: 'POST',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' },
                            body: new URLSearchParams(new FormData(form))
                        });
                        const data = await res.json();
                        if (data.ok) { window.location = data.redirect || '/'; return; }
                        err.textContent = data.error || 'Có lỗi xảy ra. Vui lòng thử lại.';
                        err.hidden = false;
                    } catch (_) {
                        err.textContent = 'Không kết nối được máy chủ. Vui lòng thử lại.';
                        err.hidden = false;
                    }
                    btn.disabled = false; btn.textContent = label;
                });
            }
            wire('loginForm', 'loginErr');
            wire('registerForm', 'registerErr');

            // Dùng thử miễn phí: 1 chạm -> submit form ẩn (tạo tài khoản dùng thử + đăng nhập)
            var trialForm = document.getElementById('trialForm');
            document.querySelectorAll('[data-trial]').forEach(function (b) {
                b.addEventListener('click', function (e) {
                    e.preventDefault();
                    b.classList.add('is-loading');
                    if (trialForm) trialForm.submit();
                });
            });
        })();
    </script>
</body>
</html>
