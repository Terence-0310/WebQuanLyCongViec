@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Cetee</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="auth-wrap">
    <div class="auth-card">
        <a asp-controller="Home" asp-action="Index" class="auth-brand" style="text-decoration:none;color:inherit;"><span class="brand-logo">C</span> Cetee</a>
        <div class="auth-sub">Quản lý công việc dự án</div>

        @if (TempData["Info"] is string info)
        {
            <div class="flash flash-info">@info</div>
        }

        <form asp-action="Login" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label class="form-label" asp-for="Email"></label>
                <input class="form-control" asp-for="Email" autofocus />
                <span class="field-error" asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Password"></label>
                <input class="form-control" asp-for="Password" />
                <span class="field-error" asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Đăng nhập</button>
        </form>

        <div class="auth-divider"><span>hoặc</span></div>
        <a class="btn btn-google btn-block" asp-action="ExternalLogin" asp-route-provider="Google"
           asp-route-returnUrl="@Model.ReturnUrl">
            <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
            <span>Đăng nhập với Google</span>
        </a>

        <div class="auth-alt">
            <a asp-action="ForgotPassword">Quên mật khẩu?</a>
        </div>
        <div class="auth-alt">
            Chưa có tài khoản? <a asp-action="Register">Đăng ký</a>
        </div>
        <div class="auth-alt">
            <a asp-controller="Home" asp-action="Index">← Về trang chủ</a>
        </div>
    </div>
</div>
</body>
</html>
