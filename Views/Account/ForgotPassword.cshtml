@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - Cetee</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="auth-wrap">
    <div class="auth-card">
        <a asp-controller="Home" asp-action="Index" class="auth-brand" style="text-decoration:none;color:inherit;"><span class="brand-logo">C</span> Cetee</a>
        <div class="auth-sub">Khôi phục mật khẩu</div>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <p class="muted text-sm">Nhập email tài khoản. Chúng tôi sẽ gửi mã OTP gồm 6 chữ số tới hộp thư của bạn.</p>

            <div class="form-group">
                <label class="form-label" asp-for="Email"></label>
                <input class="form-control" asp-for="Email" autofocus placeholder="ban@gmail.com" />
                <span class="field-error" asp-validation-for="Email"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Gửi mã OTP</button>
        </form>

        <div class="auth-alt">
            <a asp-action="Login">← Quay lại đăng nhập</a>
        </div>
    </div>
</div>
</body>
</html>
