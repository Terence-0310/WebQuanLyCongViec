@model WorkspaceFormViewModel
@{
    ViewData["Title"] = Model.IsPersonalCreator ? "Tạo không gian cá nhân" : "Tạo workspace";
}

<div class="card form-narrow">
    <div class="card-body">
        @if (Model.IsPersonalCreator)
        {
            <p class="muted mb-1">Không gian cá nhân chỉ mình bạn truy cập — dùng để sắp xếp project và công việc của riêng bạn.</p>
        }
        <form asp-action="Create" method="post">
            <partial name="_Form" model="Model" />

            @if (!Model.IsPersonalCreator)
            {
                <div class="form-group">
                    <label class="form-label">Thêm thành viên</label>
                    @if (Model.CandidateUsers.Any())
                    {
                        <div class="check-list">
                            @foreach (var u in Model.CandidateUsers)
                            {
                                <label class="check-item">
                                    <input type="checkbox" name="MemberIds" value="@u.Id" />
                                    <partial name="_Avatar" model="@u.FullName" />
                                    <span>@u.FullName <span class="muted text-sm">— @Roles.Label(u.Role?.Name)</span></span>
                                </label>
                            }
                        </div>
                        <span class="field-error muted">Bạn (người tạo) tự động là chủ sở hữu. Chỉ hiện những người trong phạm vi quản lý của bạn.</span>
                    }
                    else
                    {
                        <p class="muted text-sm">Chưa có ai trong phạm vi quản lý của bạn để thêm. Bạn sẽ là thành viên duy nhất.</p>
                    }
                </div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">@(Model.IsPersonalCreator ? "Tạo không gian" : "Tạo workspace")</button>
                <a class="btn btn-secondary" asp-action="Index">Hủy</a>
            </div>
        </form>
    </div>
</div>
