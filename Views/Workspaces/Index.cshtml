@model WorkspaceIndexViewModel
@{
    ViewData["Title"] = "Workspaces";
}

@section TopbarAction {
    <a class="btn btn-primary" asp-action="Create">@(Model.ViewerIsPersonal ? "Tạo không gian" : "Tạo workspace")</a>
}

@if (!Model.HasAny)
{
    <div class="card"><div class="empty">
        <div class="empty-title">@(Model.ViewerIsPersonal ? "Chưa có không gian làm việc" : "Chưa có workspace")</div>
        <p>
            @(Model.ViewerIsPersonal
                ? "Tạo một không gian cá nhân để sắp xếp project và công việc của riêng bạn."
                : "Tạo workspace đầu tiên để bắt đầu quản lý dự án cùng đội ngũ.")
        </p>
        <a class="btn btn-primary mt-1" asp-action="Create">@(Model.ViewerIsPersonal ? "Tạo không gian" : "Tạo workspace")</a>
    </div></div>
}
else
{
    @if (Model.Owned.Any())
    {
        <h3 class="section-heading">@(Model.ViewerIsPersonal ? "Không gian của tôi" : "Workspace tôi sở hữu") (@Model.Owned.Count)</h3>
        <div class="grid grid-3 mb-2">
            @foreach (var c in Model.Owned)
            {
                <partial name="_WorkspaceCard" model="c" />
            }
        </div>
    }

    @if (Model.Joined.Any())
    {
        <h3 class="section-heading">Tôi tham gia (@Model.Joined.Count)</h3>
        <div class="grid grid-3">
            @foreach (var c in Model.Joined)
            {
                <partial name="_WorkspaceCard" model="c" />
            }
        </div>
    }
}
