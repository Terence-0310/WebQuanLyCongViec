@model IEnumerable<Workspace>
@{
    ViewData["Title"] = "Workspaces";
}

@section TopbarAction {
    <a class="btn btn-primary" asp-action="Create">Tạo workspace</a>
}

@if (!Model.Any())
{
    <div class="card"><div class="empty">
        <div class="empty-title">Chưa có workspace</div>
        <p>Tạo workspace đầu tiên để bắt đầu quản lý dự án.</p>
        <a class="btn btn-primary mt-1" asp-action="Create">Tạo workspace</a>
    </div></div>
}
else
{
    <div class="grid grid-3">
        @foreach (var ws in Model)
        {
            <div class="card">
                <div class="card-body">
                    <div class="card-title"><a asp-action="Details" asp-route-id="@ws.Id">@ws.Name</a></div>
                    <p class="muted text-sm">@(string.IsNullOrEmpty(ws.Description) ? "Không có mô tả" : ws.Description)</p>
                    <p class="text-sm muted">@ws.Projects.Count project • @ws.Members.Count thành viên • Chủ sở hữu: @ws.Owner.FullName</p>
                    <div class="form-actions">
                        <a class="btn btn-secondary btn-sm" asp-action="Details" asp-route-id="@ws.Id">Chi tiết</a>
                        <a class="btn btn-secondary btn-sm" asp-action="Edit" asp-route-id="@ws.Id">Sửa</a>
                        <form class="inline-form" asp-action="Delete" asp-route-id="@ws.Id" method="post"
                              onsubmit="return confirm('Xóa workspace này và toàn bộ project bên trong?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
