@model Page
@{
    ViewData["Title"] = Model.Title;
}

@section TopbarAction {
    <div class="page-actions">
        <a class="btn btn-secondary" asp-action="Edit" asp-route-id="@Model.Id">Sửa</a>
        <form class="inline-form" asp-action="Delete" asp-route-id="@Model.Id" method="post"
              onsubmit="return confirm('Xóa ghi chú này?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Xóa</button>
        </form>
    </div>
}

<div class="card form-narrow">
    <div class="card-body">
        <p class="muted text-sm">
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId">@Model.Project?.Name</a>
            • Cập nhật @Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
        </p>
        <hr class="divider" />
        @if (string.IsNullOrWhiteSpace(Model.Content))
        {
            <p class="muted">(Chưa có nội dung)</p>
        }
        else
        {
            <div style="white-space: pre-wrap;">@Model.Content</div>
        }
    </div>
</div>
