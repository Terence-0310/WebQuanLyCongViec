@model WorkspaceFormViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>
<input type="hidden" asp-for="Id" />

<div class="form-group">
    <label class="form-label" asp-for="Name"></label>
    <input class="form-control" asp-for="Name" autofocus />
    <span class="field-error" asp-validation-for="Name"></span>
</div>

<div class="form-group">
    <label class="form-label" asp-for="Description"></label>
    <textarea class="form-control" asp-for="Description" rows="3"></textarea>
    <span class="field-error" asp-validation-for="Description"></span>
</div>
