    {
      "name": "7. Tài khoản khác (chạy cuối)",
      "description": "Các request này thay đổi phiên đăng nhập (đăng ký = đăng nhập user mới, đăng xuất). Để cuối để không ảnh hưởng các bước trên.",
      "item": [
        {
          "name": "POST Dùng thử miễn phí (Trial 1 chạm)",
          "protocolProfileBehavior": { "followRedirects": false },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "// Xoá cookie để chạy ở trạng thái CHƯA đăng nhập (Trial dành cho khách), rồi lấy token từ trang chủ.",
              "var base = pm.variables.get('baseUrl');",
              "function fetchToken(){ pm.sendRequest({ url: base + '/', method: 'GET' }, function (e, r) { if (!e && r) { var m = r.text().match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/); if (m) pm.collectionVariables.set('aft', m[1]); } }); }",
              "try { pm.cookies.jar().clear(base, function () { fetchToken(); }); } catch (err) { fetchToken(); }"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Trial -> redirect 302', function () { pm.expect(pm.response.code).to.be.oneOf([301, 302]); });",
              "var loc = pm.response.headers.get('Location') || '';",
              "pm.test('Tạo tài khoản dùng thử & vào Workspaces', function () { pm.expect(loc).to.include('/Workspaces'); });"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "__RequestVerificationToken", "value": "{{aft}}" }
            ] },
            "url": "{{baseUrl}}/Account/Trial",
            "description": "Tạo tài khoản dùng thử (cá nhân) + dữ liệu mẫu rồi tự đăng nhập. Nên chạy khi CHƯA đăng nhập — pre-request tự xoá cookie để mô phỏng khách vãng lai. Sau request này, phiên hiện tại là tài khoản dùng thử."
          }
        },
        {
          "name": "POST Đăng ký tài khoản mới - AJAX JSON",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "var base = pm.variables.get('baseUrl');",
              "pm.sendRequest({ url: base + '/Account/Register', method: 'GET' }, function (e, r) {",
              "  if (!e && r) { var m = r.text().match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/); if (m) pm.collectionVariables.set('aft', m[1]); }",
              "});",
              "pm.collectionVariables.set('regEmail', 'canhan_' + Date.now() + '@cetee.test');"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var j = pm.response.json();",
              "pm.test('Đăng ký ok=true', function () { pm.expect(j.ok).to.eql(true); });"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "X-Requested-With", "value": "XMLHttpRequest" }, { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "FullName", "value": "Người dùng mới" },
              { "key": "Email", "value": "{{regEmail}}" },
              { "key": "Password", "value": "User@123" },
              { "key": "ConfirmPassword", "value": "User@123" },
              { "key": "__RequestVerificationToken", "value": "{{aft}}" }
            ] },
            "url": "{{baseUrl}}/Account/Register",
            "description": "Tạo tài khoản cá nhân mới và tự đăng nhập (đổi cookie phiên sang user này)."
          }
        },
        {
          "name": "POST Quên mật khẩu (gửi OTP)",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "var base = pm.variables.get('baseUrl');",
              "pm.sendRequest({ url: base + '/Account/ForgotPassword', method: 'GET' }, function (e, r) {",
              "  if (!e && r) { var m = r.text().match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/); if (m) pm.collectionVariables.set('aft', m[1]); }",
              "});"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Chuyển sang bước nhập OTP (200/302)', function () { pm.expect(pm.response.code).to.be.oneOf([200, 302]); });"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "Email", "value": "{{adminEmail}}" },
              { "key": "__RequestVerificationToken", "value": "{{aft}}" }
            ] },
            "url": "{{baseUrl}}/Account/ForgotPassword",
            "description": "Gửi mã OTP về email (cần cấu hình SMTP trong appsettings.Development.json). Nếu email không tồn tại hệ thống vẫn trả về im lặng để chống dò tài khoản."
          }
        },
        {
          "name": "POST Đăng xuất",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "var base = pm.variables.get('baseUrl');",
              "pm.sendRequest({ url: base + '/Workspaces', method: 'GET' }, function (e, r) {",
              "  if (!e && r) { var m = r.text().match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/); if (m) pm.collectionVariables.set('aft', m[1]); }",
              "});"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Đăng xuất OK (200/302)', function () { pm.expect(pm.response.code).to.be.oneOf([200, 302]); });"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "__RequestVerificationToken", "value": "{{aft}}" }
            ] },
            "url": "{{baseUrl}}/Account/Logout"
          }
        }
      ]
    }
  ]
}
