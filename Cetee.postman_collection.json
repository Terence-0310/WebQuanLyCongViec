            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "Title", "value": "Task Demo (Postman)" },
              { "key": "Description", "value": "Task test API" },
              { "key": "ProjectId", "value": "{{projectId}}" },
              { "key": "Priority", "value": "1" },
              { "key": "Status", "value": "0" },
              { "key": "DurationMinutes", "value": "60" },
              { "key": "__RequestVerificationToken", "value": "{{aft}}" }
            ] },
            "url": "{{baseUrl}}/Tasks/Create",
            "description": "Priority: 0=Thấp,1=TB,2=Cao | Status: 0=Cần làm,1=Đang làm,2=Hoàn thành."
          }
        },
        {
          "name": "GET Chi tiết Task",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
          ] } } ],
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/Tasks/Details/{{taskId}}" }
        },
        {
          "name": "POST Xếp lịch Task (Schedule) - AJAX JSON",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "var base = pm.variables.get('baseUrl');",
              "pm.sendRequest({ url: base + '/Tasks/Timeline', method: 'GET' }, function (e, r) {",
              "  if (!e && r) { var m = r.text().match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/); if (m) pm.collectionVariables.set('aft', m[1]); }",
              "});",
              "// Giờ bắt đầu = hôm nay 09:00",
              "var d = new Date(); var iso = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0') + 'T09:00';",
              "pm.collectionVariables.set('scheduleStart', iso);"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var j = pm.response.json();",
              "pm.test('Xếp lịch ok=true', function () { pm.expect(j.ok).to.eql(true); });"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "X-Requested-With", "value": "XMLHttpRequest" }, { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "id", "value": "{{taskId}}" },
              { "key": "start", "value": "{{scheduleStart}}" },
              { "key": "duration", "value": "90" },
              { "key": "__RequestVerificationToken", "value": "{{aft}}" }
            ] },
            "url": "{{baseUrl}}/Tasks/Schedule"
          }
        },
        {
