    {
      "name": "5. Tasks",
      "item": [
        {
          "name": "POST Tạo Task",
          "protocolProfileBehavior": { "followRedirects": false },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "var base = pm.variables.get('baseUrl');",
              "var p = pm.collectionVariables.get('projectId');",
              "pm.sendRequest({ url: base + '/Tasks/Create?projectId=' + p, method: 'GET' }, function (e, r) {",
