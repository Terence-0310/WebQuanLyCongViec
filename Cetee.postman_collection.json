{
  "info": {
    "name": "Cetee - Demo Test Full (ASP.NET Core MVC)",
    "description": "Bộ kịch bản test end-to-end cho dự án Cetee.\n\nLưu ý: Cetee là ứng dụng ASP.NET Core MVC dùng Cookie Identity + Antiforgery token, KHÔNG phải REST API thuần. Vì vậy collection này:\n- Dùng Cookie jar của Postman (tự lưu cookie đăng nhập giữa các request).\n- Mỗi request POST có pre-request script tự lấy __RequestVerificationToken từ trang form tương ứng rồi gửi kèm.\n- Đăng nhập/Đăng ký gọi qua endpoint AJAX (header X-Requested-With) nên trả JSON.\n- Các lệnh tạo (workspace/project/task) tắt follow-redirect để bắt Id từ header Location.\n\nCÁCH CHẠY: bật Cookie jar (mặc định bật), đặt biến baseUrl đúng cổng, rồi Run Collection theo thứ tự thư mục 1 -> 7.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5259" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "Admin@123" },
    { "key": "aft", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login (Admin) - AJAX JSON",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Lấy antiforgery token từ trang đăng nhập (đồng thời set cookie antiforgery)",
                  "var base = pm.variables.get('baseUrl');",
                  "pm.sendRequest({ url: base + '/Account/Login', method: 'GET' }, function (e, r) {",
                  "  if (!e && r) {",
                  "    var m = r.text().match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/);",
                  "    if (m) pm.collectionVariables.set('aft', m[1]);",
                  "  }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('Đăng nhập thành công (ok=true)', function () { pm.expect(j.ok).to.eql(true); });",
                  "pm.test('Có URL chuyển hướng', function () { pm.expect(j.redirect).to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Requested-With", "value": "XMLHttpRequest" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "Email", "value": "{{adminEmail}}" },
                { "key": "Password", "value": "{{adminPassword}}" },
                { "key": "__RequestVerificationToken", "value": "{{aft}}" }
              ]
            },
            "url": "{{baseUrl}}/Account/Login",
            "description": "Đăng nhập SuperAdmin qua AJAX (trả JSON). Cookie phiên được lưu vào cookie jar dùng cho các request sau."
          }
        }
      ]
    },
    {
      "name": "2. Dashboard",
      "item": [
        {
          "name": "GET Dashboard",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200 (đã đăng nhập)', function () { pm.response.to.have.status(200); });"
            ] } }
          ],
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/Dashboard" }
        }
      ]
    },
    {
      "name": "3. Workspaces",
      "item": [
        {
          "name": "GET danh sách Workspaces",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
          ] } } ],
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/Workspaces" }
        },
        {
          "name": "POST Tạo Workspace",
          "protocolProfileBehavior": { "followRedirects": false },
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "var base = pm.variables.get('baseUrl');",
              "pm.sendRequest({ url: base + '/Workspaces/Create', method: 'GET' }, function (e, r) {",
              "  if (!e && r) { var m = r.text().match(/name=\"__RequestVerificationToken\"[^>]*value=\"([^\"]+)\"/); if (m) pm.collectionVariables.set('aft', m[1]); }",
              "});"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Tạo thành công -> redirect 302', function () { pm.expect(pm.response.code).to.be.oneOf([301, 302]); });",
              "var loc = pm.response.headers.get('Location') || '';",
              "var m = loc.match(/(\\d+)\\/?$/);",
              "if (m) pm.collectionVariables.set('workspaceId', m[1]);",
              "pm.test('Bắt được workspaceId', function () { pm.expect(pm.collectionVariables.get('workspaceId')).to.match(/\\d+/); });"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/x-www-form-urlencoded" } ],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "Name", "value": "Workspace Demo (Postman)" },
              { "key": "Description", "value": "Tạo từ Postman để test" },
              { "key": "__RequestVerificationToken", "value": "{{aft}}" }
            ] },
            "url": "{{baseUrl}}/Workspaces/Create"
          }
        },
        {
          "name": "GET Chi tiết Workspace",
          "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
          ] } } ],
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/Workspaces/Details/{{workspaceId}}" }
        }
      ]
    },
    {
      "name": "4. Projects",
